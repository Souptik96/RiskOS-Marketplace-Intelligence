# Agent API Configuration
AGENT_API_URL=http://localhost:7861

# dbt Configuration
DBT_PROFILES_DIR=./dbt_project/profiles

# LLM Provider Configuration
LLM_PROVIDER=fireworks
FIREWORKS_API_KEY= # (or ensure it's set in Space settings)
FIREWORKS_MODEL_ID=accounts/fireworks/models/deepseek-v3p1-terminus
FIREWORKS_URL_CHAT=https://api.fireworks.ai/inference/v1/chat/completions
FIREWORKS_URL_COMP=https://api.fireworks.ai/inference/v1/completions

LLM_MODEL_GEN=accounts/fireworks/models/deepseek-v3p1-terminus
LLM_MODEL_REV=accounts/fireworks/models/deepseek-v3p1-terminus

# Cache Configuration
TRANSFORMERS_CACHE=/tmp/cache/transformers
HF_HOME=/tmp/cache/hf
HF_HUB_CACHE=/tmp/cache/hf/hub
XDG_CACHE_HOME=/tmp/cache
TORCH_HOME=/tmp/cache/torch